# homelab-infra setup configuration
#
# Usage:
#   cp secrets.example secrets.env
#   # Edit secrets.env with your values
#   ./setup.sh --config secrets.env
#
# secrets.env is gitignored — never commit it.
# Leave a value blank to be prompted interactively, or to auto-generate (for passwords).

# ── Cluster identity ──────────────────────────────────────────────────────────
OWNER_NAME=homelab
DOMAIN=homelab.local
GITHUB_USER=YOUR_GITHUB_USERNAME
GITHUB_REPO=homelab-infra
CP_IP=10.0.0.10
CP_HOST=control-plane
GATEWAY_IP=10.0.0.1
LB_START=10.0.0.200
REGISTRY_HOST=

# ── Worker nodes (leave blank to skip pinning) ────────────────────────────────
WORKER_1=
WORKER_2=
WORKER_3=
WORKER_4=

# ── Node specialization (leave blank to schedule anywhere) ────────────────────
GPU_NODE=
STORAGE_NODE=
NFS_NODE=

# ── NFS / Storage ─────────────────────────────────────────────────────────────
NFS_SERVER=nfs.homelab.local
NFS_SERVER_2=nfs2.homelab.local
NFS_BASE=/nfs/data
NFS_KUBE=/nfs/kube
MUSIC_HOST_PATH=/opt/data/music-assistant

# ── GPG key for SOPS (required) ───────────────────────────────────────────────
# Run: gpg --list-secret-keys --keyid-format LONG
GPG_KEY_ID=

# ── Secrets (leave blank to auto-generate) ────────────────────────────────────
REGISTRY_PASS=
PG_PASS=
KEYCLOAK_PASS=
GRAFANA_PASS=
JENKINS_PASS=
ARGOCD_PASS=
FOREMAN_PASS=
NEXTCLOUD_PASS=

# ── Cert-manager / DNS ────────────────────────────────────────────────────────
ACME_EMAIL=admin@homelab.local
CF_TOKEN=
CF_EMAIL=
SMTP_PASS=

# ── Networking ────────────────────────────────────────────────────────────────
PIHOLE_LB_IP=10.0.0.201
NGINX_LB_IP=10.0.0.202
DNS_SERVER_1=8.8.8.8
DNS_SERVER_2=8.8.4.4
WINDOWS_NODE_IP=

# ── Additional credentials (leave blank to skip) ──────────────────────────────
GITHUB_PAT=
TAILSCALE_CLIENT_ID=
TAILSCALE_CLIENT_SECRET=

# ── Jenkins keystore (leave blank if not using JNLP TLS) ─────────────────────
JENKINS_KEYSTORE_B64=
JENKINS_KEYSTORE_PASS=

# ── OpenClaw / WhatsApp (leave blank to skip) ─────────────────────────────────
YOUR_PHONE=
WHATSAPP_GROUP_ID=

# ── LLM / AI services (leave blank to skip) ───────────────────────────────────
DISCORD_TOKEN=
LITELLM_KEY=
SEARXNG_SECRET=
